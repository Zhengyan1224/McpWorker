{
  "AllowedHosts": "*",
  "Kestrel": {
    "EndPoints": {
      "Http": {
        "Url": "http://*:5176"
      }
    }
  },
  "Swagger": {
    "Enable": true,
    "Tile": "文本实体提取服务接口",
    "Version": "v1.0.0",
    "Description": "用于文本实体提取服务接口的调用说明。",
    "XmlComments": [
      "./profiles/Comments.xml"
    ]
  },

  "StaticFiles": {
    "StaticFilesRoot": "./wwwroot",
    "RequestPath": "",
    "DefaultFiles": [
      "login.html"
    ],
    "ContentTypeMappings": [
      {
        "FileExtension": ".mobi",
        "ContentType": "application/octet-stream"
      },
      {
        "FileExtension": ".epub",
        "ContentType": "application/octet-stream"
      },
      {
        "FileExtension": ".azw3",
        "ContentType": "application/octet-stream"
      }
    ]
  },
  "Logger": {
    "Level": "Info", // 支持Verb/Debug/Info/Warn/Error/Fatal
    "Outputs": [
      {
        "Type": "File", // 支持File（文件）/Console（控制台）两种类型
        "Path": "Logs/log.txt", // 输出路径
        "Template": "{Timestamp:yyyy-MM-dd HH:mm-ss.fff }[{Level:u3}] {Message:lj}{NewLine}{Exception}", // 输出格式模板
        "RollingInterval": "Day", // 支持Infinite（不按时间）/Year（按年）/Month（按月）/Day（按日）/Hour（按时）/Minute（按分）
        "FileSizeLimitBytes": 0, //日志文件大小最大上限（Byte，0为不限制大小）
        "Encoding": "GBK", // 日志文件编码
        "RetainedFileCountLimit": 10 // 最大保存文件数,超过最大文件数会自动覆盖原有文件
      },
      {
        "Type": "Console",
        "Template": "{Timestamp:yyyy-MM-dd HH:mm-ss.fff }[{Level:u3}] {Message:lj}{NewLine}{Exception}"
      }
    ]
  }
}
