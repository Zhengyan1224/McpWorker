{
  "DataDirectoryPath": "./data",
  "CacheDirectoryPath": "./cache",
  "DefaultTopN": 5,
  "MaxTopN": 20,
  "EmbeddingBatchSize": 64,
  "MaxRecordsForEmbedding": 5000,
  "ApproximateSearchCandidateMultiplier": 6,
  "Embedding": {
    "Enabled": true,
    "Model": "bge_m3",
    "Endpoint": "http://10.10.40.102:32730/openapi/373cd113-3840-4b83-99bd-b228847cfc7b/v1/embeddings",
    "ApiKey": "Vjdgwco4QeETBgqqD7iNPjfqn8yKpxvokTYyUR3eWkQ",
    "TimeoutSeconds": 60,
    "MaxTextLengthPerRecord": 2000
  },
  "Logger": {
    "Level": "Debug",
    "Outputs": [
      {
        "Type": "File",
        "Path": "logs/dataquery_log.txt",
        "Template": "{Timestamp:yyyy-MM-dd HH:mm-ss.fff }[{Level:u3}] {Message:lj}{NewLine}{Exception}",
        "RollingInterval": "Day",
        "FileSizeLimitBytes": 0,
        "Encoding": "UTF-8",
        "RetainedFileCountLimit": 10
      },
      {
        "Type": "Console",
        "Template": "{Timestamp:yyyy-MM-dd HH:mm-ss.fff }[{Level:u3}] {Message:lj}{NewLine}{Exception}"
      }
    ]
  }
}
